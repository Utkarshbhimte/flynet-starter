node_modules
.next
out
build

# env — keep .env.example, never commit real secrets
.env
.env.local
.env*.local

.DS_Store
*.tsbuildinfo
next-env.d.ts

# dev-journey state lives in .flynet/ and IS committed (progress.json,
# journey.json) — only the transient lockdirs and temp files are ignored
.flynet/*.lock
.flynet/*.tmp.*

# Local Claude Code sessions: the daemon's pidfile holds a token, and the
# transcripts are per-machine runtime state — never commit them.
.flynet/sessions/
